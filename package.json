    "bullmq": "^5.8.3",
    "dotenv": "^16.4.5",
    "graphql": "^16.8.2",
    "graphql-yoga": "^5.3.0",
    "hono": "^4.4.2",
    "ioredis": "^5.4.1",
    "jose": "^5.4.0",
    "node-cron": "^3.0.3",
    "pino": "^9.2.0",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.10",
    "eslint": "^8.57.0",
    "ioredis-mock": "^8.9.0",

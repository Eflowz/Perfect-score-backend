    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@prisma/client": "^5.15.0",
    "awilix": "^10.0.1",
